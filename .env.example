# Database
DATABASE_URL="postgresql://usuario:password@host:5432/nombre_db?schema=public"

# Auth
JWT_SECRET="cambia-este-secret-en-produccion-usa-algo-muy-largo-y-aleatorio"

# Upload
UPLOAD_DIR="./public/uploads"

# App
NEXT_PUBLIC_APP_NAME="Portal Ciudadano"
NEXT_PUBLIC_APP_URL="https://tu-app.vercel.app"

# Email (SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="tu-email@gmail.com"
SMTP_PASSWORD="tu-contraseña-de-aplicacion"
SMTP_FROM="noreply@tsjchihuahua.gob.mx"

# AWS S3 (file storage)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET_NAME=portal-ciudadano-docs

# AWS SES (email)
SES_SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SES_SMTP_USER=your-ses-smtp-user
SES_SMTP_PASSWORD=your-ses-smtp-password
